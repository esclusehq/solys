# Umami Database - RDS PostgreSQL connection
DATABASE_URL=postgresql://umami:YOUR_RDS_PASSWORD@analytics-db.xxxxxxx.ap-southeast-1.rds.amazonaws.com:5432/umami?sslmode=require

# Generate with: openssl rand -hex 32
APP_SECRET=replace-with-openssl-rand-hex-32-output

# Tracker script renamed to evade ad blockers
TRACKER_SCRIPT_NAME=analytics.js

# Collect API endpoint renamed to evade ad blockers
COLLECT_API_ENDPOINT=/api/collect

# Disable telemetry and update checks
DISABLE_TELEMETRY=1
DISABLE_UPDATES=1
